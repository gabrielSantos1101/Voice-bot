# ArcaneVoice environment example.
# Copy this file to .env and fill in real secrets locally or in your hosting
# provider. Do not commit real tokens.

# Required to run the Discord bot.
BOT_TOKEN=your-discord-bot-token

# HTTP server port (optional, default: 4001).
PORT=4001

# Bot status (optional, default: "voice").
BOT_PRESENCE=voice
BOT_PRESENCE_TYPE=3

# Optional: Redis for future features. Leave unset to skip.
# REDIS_HOST=localhost
